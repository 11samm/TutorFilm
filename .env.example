# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# Nano Banana 2 (image generation)
NANO_BANANA_API_KEY=your_nano_banana_api_key

# Veo (video generation)
VEO_API_KEY=your_veo_api_key

# Lyria 3 (music generation)
LYRIA_API_KEY=your_lyria_api_key

# Pre-baked default avatar 4-angle sheet URLs
NEXT_PUBLIC_DEFAULT_MALE_ANGLES_URL=https://example.com/default-male-angles.png
NEXT_PUBLIC_DEFAULT_FEMALE_ANGLES_URL=https://example.com/default-female-angles.png

# Demo mode (optional — skip generation and show pre-built video)
NEXT_PUBLIC_DEMO_VIDEO_URL=
